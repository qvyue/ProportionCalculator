{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "proportion-calculator.com"
        }
      ],
      "destination": "https://www.proportion-calculator.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/proportion/examples",
      "destination": "/proportion/examples/index.html"
    }
  ]
}
